{
  "name": "learner-sig",
  "version": "0.1.0",
  "description": "MVP tahap 1 untuk discovery portal simulasi pembelajaran korporasi.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "discover": "tsx src/index.ts discover",
    "save-session": "tsx src/index.ts save-session",
    "discover:session": "tsx src/index.ts discover --session",
    "run-videos": "tsx src/index.ts run-videos",
    "run-videos:session": "tsx src/index.ts run-videos --session",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "playwright": "^1.49.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
